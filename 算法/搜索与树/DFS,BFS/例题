#include<bits/stdc++.h>
using namespace std;
typedef long long ll;
int n,m,ans;
char mp[105][105],vis[105][105]={0};
int dx[9]={0,0,1,-1,1,1,-1,-1},dy[9]={1,-1,0,0,1,-1,1,-1};
void dfs(int x,int y)
{
    vis[x][y]=1;
    for(int i=0;i<8;i++)
    {
        int nx=x+dx[i],ny=y+dy[i];
        if(nx>=1&&nx<=n&&ny>=1&&ny<=m)
        {
            if(mp[nx][ny]=='W'&&!vis[nx][ny])
            dfs(nx,ny);
        }
    }
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr); 
    cin>>n>>m;
    ans=0;
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=m;j++)
        cin>>mp[i][j];
    }
    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=m;j++)
        {
            if(mp[i][j]=='W'&&!vis[i][j])
            {
                ans++;
                dfs(i,j);
            }
        }
    }
    cout<<ans<<'\n';
    return 0;
}
