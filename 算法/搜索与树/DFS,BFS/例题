```
#include<bits/stdc++.h>
using namespace std;
typedef long long ll;
int N,M;
char mp[105][105],vis[105][105];
int dx[9]={1,0,0,-1,1,1,-1,-1},dy[9]={0,1,-1,0,1,-1,1,-1};
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr); 
    cin>>N>>M;
    for(int i=1;i<=N;i++)
    {
        for(int j=1;j<=M;j++)
        {
            cin>>mp[i][j];
            vis[i][j]=false;
        }
    }
    int pond=0;
    for(int i=1;i<=N;i++)
    {
        for(int j=1;j<=M;j++)
        {
            if(mp[i][j]=='W'&&!vis[i][j])
            {
                pond++;
                queue<pair<int,int>>q;
                q.push({i,j});
                vis[i][j]=true;
                while(!q.empty())
                {
                    pair<int,int> it=q.front();
                    q.pop();
                    for(int k=0;k<8;k++)
                    {
                        int nx=it.first+dx[k],ny=it.second+dy[k];
                        if(nx>=1&&nx<=N&&ny>=1&&ny<=M&&mp[nx][ny]=='W'&&!vis[nx][ny])
                        {
                            vis[nx][ny]=true;
                            q.push({nx,ny});
                        }
                    }
                }
            }
        }
    }
    cout<<pond<<endl;
    return 0;
}
